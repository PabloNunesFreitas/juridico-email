# ── Segurança ──────────────────────────────────────────────────
JWT_SECRET=troque-por-uma-string-aleatoria-longa

# ── Admin inicial ──────────────────────────────────────────────
SEED_ADMIN_EMAIL=admin@suaempresa.com.br
SEED_ADMIN_PASSWORD=senha-forte-aqui

# ── Banco de dados ─────────────────────────────────────────────
DATABASE_URL=postgresql+psycopg2://usuario:senha@host:5432/banco

# ── E-mail ─────────────────────────────────────────────────────
EMAIL_PROVIDER=gmail
CENTRAL_EMAIL=seuemail@suaempresa.com.br

GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=

OUTLOOK_CLIENT_ID=
OUTLOOK_CLIENT_SECRET=
OUTLOOK_TENANT_ID=
OUTLOOK_REFRESH_TOKEN=

# ── Sincronização automática ───────────────────────────────────
AUTO_SYNC_ENABLED=true
AUTO_SYNC_INTERVAL_SECONDS=60

# ── Keep-alive (Render.com free tier) ─────────────────────────
SELF_PING_URL=

# ── Limite do primeiro sync (dias para trás; 0 = sem limite) ──
SYNC_INITIAL_DAYS=180

# ── CORS (separar por vírgula se mais de uma origem) ──────────
CORS_ORIGINS=https://seu-frontend.vercel.app
